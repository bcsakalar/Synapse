# ─── Database ───
DATABASE_URL=postgresql://synapse:synapse@localhost:5488/synapse
DATABASE_URL_DOCKER=postgresql://synapse:synapse@postgres:5432/synapse

# ─── Redis ───
REDIS_URL=redis://localhost:6399
REDIS_URL_DOCKER=redis://redis:6379

# ─── AI ───
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Auth ───
JWT_SECRET=your_jwt_secret_here_min_32_chars

# ─── Encryption (32-byte hex = 64 hex chars for AES-256-GCM) ───
ENCRYPTION_KEY=your_64_hex_char_encryption_key_here_0000000000000000000000000000

# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3099
NODE_ENV=development
